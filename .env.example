# Required — DigitalOcean Gradient™ AI
GRADIENT_API_KEY=your_gradient_api_key_here

# Optional — defaults shown
GRADIENT_ENDPOINT=https://inference.do-ai.run/v1/chat/completions
# BROWSER_AGENT_MODEL: Use llama3.3-70b-instruct for best reasoning (DOM-based), 
# or llama3.2-vision for screenshot-based reasoning.
BROWSER_AGENT_MODEL=llama3.3-70b-instruct
BROWSER_HEADLESS=true
# DEMO_MODE=1 enables /demo/* endpoints (start_task, status, user_reply, screenshot, hard_stop)
# Set to 0 for production deployments without demo surface
DEMO_MODE=1
CHROME_EXECUTABLE=
PORT=8080
RUST_LOG=info
